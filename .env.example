# LexResolve-style CMS base (same as Lawyer-application-deploy VITE_APPS_SCRIPT_URL)
# Dev: leave unset to use /api/content (proxied to backend)
# VITE_APPS_SCRIPT_URL=http://localhost:3001/api/content

# Optional SSR / direct API host
# VITE_API_URL=http://localhost:3001

# Deploy (Cloudflare Worker): backend origin for /api proxy
# API_PROXY_TARGET=https://your-api.example.com

# Admin login: ADMIN_USERNAME / ADMIN_PASSWORD in backend/.env only
