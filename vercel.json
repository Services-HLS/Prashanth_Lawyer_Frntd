{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://prashanth-lawyer-bknd.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://prashanth-lawyer-bknd.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/|assets/|site\\.html|cms-site\\.js|profile\\.jpg|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
