{
  "buildCommand": "npm run build",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://prashanth-lawyer-bknd.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://prashanth-lawyer-bknd.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
